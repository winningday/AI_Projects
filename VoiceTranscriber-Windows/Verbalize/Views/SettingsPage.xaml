<Page x:Class="Verbalize.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

            <!-- Hotkey -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Push-to-Talk Hotkey" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Hold this key to record, release to transcribe" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="16,8"
                                MinWidth="80">
                            <TextBlock x:Name="HotkeyText" Text="F8" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryLightBrush}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{StaticResource MonoFont}" />
                        </Border>
                        <Button x:Name="ChangeHotkeyBtn" Content="Change Hotkey"
                                Style="{StaticResource SecondaryButton}"
                                Margin="12,0,0,0" Click="ChangeHotkey_Click" Padding="14,8" FontSize="13" />
                    </StackPanel>
                    <TextBlock x:Name="HotkeyHint" Text="" FontSize="11"
                               Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- General -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <CheckBox x:Name="SoundEffectsCheck" Content="Sound effects on start/stop"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />

                    <CheckBox x:Name="AutoInjectCheck" Content="Auto-paste transcription into active field"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />

                    <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to system tray on close"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />

                    <CheckBox x:Name="LaunchAtStartupCheck" Content="Launch at Windows startup"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Checked="Setting_Changed" Unchecked="Setting_Changed" />
                </StackPanel>
            </Border>

            <!-- Transcription Engine -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Transcription Engine" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Choose which speech-to-text engine to use" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />

                    <RadioButton x:Name="EngineWhisperMini" GroupName="Engine"
                                 Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                 Margin="0,0,0,2" Checked="Engine_Changed">
                        <StackPanel>
                            <TextBlock Text="OpenAI Whisper (Fast)" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="gpt-4o-mini-transcribe — fast, good accuracy" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="EngineWhisperFull" GroupName="Engine"
                                 Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                 Margin="0,6,0,2" Checked="Engine_Changed">
                        <StackPanel>
                            <TextBlock Text="OpenAI Whisper (Accurate)" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="gpt-4o-transcribe — best accuracy, slightly slower" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="EngineDeepgram" GroupName="Engine"
                                 Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                 Margin="0,6,0,0" Checked="Engine_Changed">
                        <StackPanel>
                            <TextBlock Text="Deepgram Nova-2" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="Nova-2 — very fast, great accuracy" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Text Cleanup -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Text Cleanup" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="How transcribed text is cleaned up before pasting" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />

                    <CheckBox x:Name="UseAICleanupCheck" Content="Use AI cleanup (Claude Haiku)"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,4" Checked="Setting_Changed" Unchecked="Setting_Changed" />
                    <TextBlock x:Name="CleanupDescription"
                               Text="Fast programmatic cleanup: capitalizes, adds punctuation, removes fillers. Your words are never changed."
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="20,0,0,12" TextWrapping="Wrap" />

                    <Separator Margin="0,4,0,12" />

                    <CheckBox x:Name="ContextAwarenessCheck" Content="Context awareness (detect active app)"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />

                    <CheckBox x:Name="SmartFormattingCheck" Content="Smart formatting (code, URLs, lists)"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,8" Checked="Setting_Changed" Unchecked="Setting_Changed" />

                    <CheckBox x:Name="AutoDictionaryCheck" Content="Auto-add corrected words to dictionary"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Checked="Setting_Changed" Unchecked="Setting_Changed" />
                </StackPanel>
            </Border>

            <!-- Translation -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Translation" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <CheckBox x:Name="TranslationCheck" Content="Enable real-time translation"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                              Margin="0,0,0,10" Checked="Translation_Changed" Unchecked="Translation_Changed" />

                    <StackPanel x:Name="LanguagePanel" Orientation="Horizontal" Margin="20,0,0,0">
                        <TextBlock Text="Target language:" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="LanguageCombo" Width="160"
                                  SelectionChanged="LanguageCombo_Changed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Typing Speed -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Your Typing Speed" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Used to calculate speed comparison in Stats" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TypingSpeedBox" Style="{StaticResource DarkTextBox}"
                                 Width="80" TextChanged="TypingSpeed_Changed" />
                        <TextBlock Text="WPM" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- API Keys -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="API Keys" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <TextBlock Text="OpenAI API Key (for Whisper engines)" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="OpenAIKeyBox" Background="{StaticResource BgTertiaryBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" FontSize="14"
                                     PasswordChanged="OpenAIKey_Changed" />
                    </Grid>

                    <TextBlock Text="Anthropic API Key (for Claude Audio / AI cleanup)" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="AnthropicKeyBox" Background="{StaticResource BgTertiaryBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" FontSize="14"
                                     PasswordChanged="AnthropicKey_Changed" />
                    </Grid>

                    <TextBlock Text="Deepgram API Key (for Deepgram Nova-2)" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <Grid>
                        <PasswordBox x:Name="DeepgramKeyBox" Background="{StaticResource BgTertiaryBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" FontSize="14"
                                     PasswordChanged="DeepgramKey_Changed" />
                    </Grid>

                    <TextBlock Text="Keys are stored locally with base64 obfuscation." FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Data -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Data" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <Button Content="Clear All Transcripts" Style="{StaticResource SecondaryButton}"
                            Foreground="{StaticResource ErrorBrush}" Click="ClearData_Click"
                            Padding="14,8" FontSize="13" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Version -->
            <TextBlock Text="Verbalize for Windows v1.0.0" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"
                       Margin="0,8,0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>
