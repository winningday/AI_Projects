# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Drive (Optional - for user profile sync)
GOOGLE_DRIVE_DOCUMENT_ID=your_google_drive_document_id_here
GOOGLE_DRIVE_CREDENTIALS_PATH=credentials.json

# Instagram (for reference)
INSTAGRAM_USERNAME=your_instagram_username_here

# Posting Configuration
MIN_DELAY=8
MAX_DELAY=20
MAX_POSTS_PER_BATCH=10
BATCH_COOLDOWN=300

# Database
DATABASE_PATH=data/comments.db

# Session Management
SESSION_FILE_PATH=data/session.json
