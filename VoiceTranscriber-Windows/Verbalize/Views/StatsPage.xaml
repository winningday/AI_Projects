<Page x:Class="Verbalize.Views.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Productivity Stats" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
            <TextBlock Text="See how voice transcription boosts your productivity" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

            <!-- Speed Comparison Hero Card -->
            <Border Background="#2D6366F1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Voice vs Typing Speed" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="SpeedMultiplierText" Text="--x faster" FontSize="42" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryLightBrush}" HorizontalAlignment="Center"
                               Margin="0,8,0,4" />
                    <TextBlock x:Name="SpeedDetailText" Text="" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Metrics Grid -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total Words" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="TotalWordsText" Text="0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Total Transcripts" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="TotalTranscriptsText" Text="0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Recording Time" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="RecordingTimeText" Text="0m" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Weekly Activity -->
            <TextBlock Text="This Week" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <Grid Height="120" x:Name="WeeklyChart">
                    <!-- Bars rendered in code-behind -->
                </Grid>
            </Border>

            <!-- Additional Stats -->
            <UniformGrid Columns="2" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Avg Words/Transcript" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="AvgWordsText" Text="0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Time Saved" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="TimeSavedText" Text="0 min" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
