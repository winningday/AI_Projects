<Window x:Class="Verbalize.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Verbalize" Width="520" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Welcome to Verbalize" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryLightBrush}" />
            <TextBlock Text="Let's get you set up in 2 steps" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />

            <!-- Progress -->
            <ProgressBar x:Name="StepProgress" Value="0" Maximum="2" Height="4"
                         Margin="0,16,0,0" Background="{StaticResource BgTertiaryBrush}"
                         Foreground="{StaticResource PrimaryBrush}" />
        </StackPanel>

        <!-- Step Content -->
        <StackPanel Grid.Row="1">
            <!-- Step 1: Microphone -->
            <StackPanel x:Name="Step1Panel">
                <TextBlock Text="Step 1: Microphone Access" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,16">
                    Verbalize needs access to your microphone to record your voice.
                    Windows will prompt you for permission when you first record.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                    If you've previously denied access, go to:
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="{StaticResource MonoFont}"
                           Foreground="{StaticResource PrimaryLightBrush}" Margin="0,8,0,0">
                    Settings > Privacy &amp; Security > Microphone
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,12,0,0">
                    Make sure Verbalize (or Desktop apps) is allowed.
                </TextBlock>
            </StackPanel>

            <!-- Step 2: API Keys -->
            <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                <TextBlock Text="Step 2: API Keys" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,16">
                    Verbalize uses OpenAI Whisper for transcription and optionally Anthropic Claude for AI text cleanup.
                </TextBlock>

                <TextBlock Text="OpenAI API Key (required)" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="OnboardOpenAIKey" Background="{StaticResource BgTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="14" Margin="0,0,0,12" />

                <TextBlock Text="Anthropic API Key (optional)" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="OnboardAnthropicKey" Background="{StaticResource BgTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="14" Margin="0,0,0,8" />

                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    Without the Anthropic key, transcriptions won't be cleaned by AI — raw Whisper output will be used.
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Navigation -->
        <DockPanel Grid.Row="2">
            <Button x:Name="BackBtn" Content="Back" DockPanel.Dock="Left"
                    Style="{StaticResource SecondaryButton}" Click="Back_Click"
                    Visibility="Collapsed" Padding="16,10" />
            <Button x:Name="NextBtn" Content="Next" DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButton}" Click="Next_Click"
                    HorizontalAlignment="Right" Padding="24,10" />
        </DockPanel>
    </Grid>
</Window>
