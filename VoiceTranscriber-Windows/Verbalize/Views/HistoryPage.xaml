<Page x:Class="Verbalize.Views.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Verbalize.Converters"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Transcript History" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Style="{StaticResource DarkTextBox}"
                     TextChanged="SearchBox_TextChanged" />
            <TextBlock Text="Search transcripts..." FontSize="14"
                       Foreground="{StaticResource TextMutedBrush}" Margin="12,8,0,0"
                       IsHitTestVisible="False"
                       Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
        </Grid>

        <!-- Transcript List + Detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- List -->
            <ListBox x:Name="TranscriptList" Grid.Column="0" Margin="0,0,8,0"
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="TranscriptList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding WordCount, StringFormat='{}{0} words'}"
                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding Timestamp, StringFormat='MMM d, h:mm tt'}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </DockPanel>
                                <TextBlock Text="{Binding CleanedText}" FontSize="13" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="36"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            CornerRadius="{StaticResource MediumRadius}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel">
                        <TextBlock x:Name="NoSelectionText" Text="Select a transcript to view details"
                                   FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,40,0,0" />

                        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                            <TextBlock Text="Cleaned Text" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                            <TextBlock x:Name="CleanedTextBlock" FontSize="14" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

                            <TextBlock Text="Original (Raw)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                            <TextBlock x:Name="OriginalTextBlock" FontSize="13" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Duration: " FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="DurationText" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="  |  Words: " FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0" />
                                <TextBlock x:Name="WordCountText" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Copy" Style="{StaticResource SecondaryButton}"
                                        Click="CopyButton_Click" Padding="12,6" FontSize="12" />
                                <Button Content="Delete" Style="{StaticResource SecondaryButton}"
                                        Click="DeleteButton_Click" Padding="12,6" FontSize="12" Margin="8,0,0,0"
                                        Foreground="{StaticResource ErrorBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
