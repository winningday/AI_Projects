<Page x:Class="Verbalize.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Verbalize.Converters"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel MaxWidth="700">
            <!-- Header -->
            <TextBlock Text="Home" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
            <TextBlock Text="Your voice transcription dashboard" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

            <!-- Error Banner -->
            <Border Background="#3DEF4444" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           FontSize="13" TextWrapping="Wrap" />
            </Border>

            <!-- Quick Stats Row -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <!-- Words Today -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Total Words" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding TotalWords}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryLightBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- WPM -->
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Voice WPM" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="WpmText" Text="--" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Transcripts -->
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Transcripts" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="TranscriptCountText" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Speed Multiplier -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Speed" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="SpeedText" Text="--x" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Translation Status -->
            <Border Background="#3D6366F1" CornerRadius="8" Padding="14" Margin="0,0,0,16"
                    x:Name="TranslationBanner" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Translation Active:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryLightBrush}" />
                    <TextBlock x:Name="TranslationLanguageText" FontSize="13" Margin="6,0,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Recent Transcripts -->
            <TextBlock Text="Recent Transcripts" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

            <ItemsControl x:Name="GroupedList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- Date group header -->
                            <TextBlock Text="{Binding Key}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,8" />
                            <!-- Transcripts in this group -->
                            <ItemsControl ItemsSource="{Binding Transcripts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Cursor="Hand">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding WordCount, StringFormat='{}{0} words'}"
                                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding TimeDisplay}"
                                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding CleanedText}" FontSize="14" Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxHeight="40"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="EmptyStateText" Text="No transcripts yet. Hold your hotkey to start recording!"
                       FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</Page>
