<Window x:Class="Verbalize.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Verbalize.Converters"
        Title="Verbalize"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Logo & Title -->
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,10">
                    <TextBlock Text="Verbalize" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryLightBrush}"
                               FontFamily="{StaticResource DefaultFont}" />
                    <TextBlock Text="Voice to Text" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <!-- Status Bar -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        Background="{StaticResource BgTertiaryBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                     Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                            <TextBlock Text="{Binding StatusText}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock Margin="16,4,0,0" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Hold " />
                            <Run Text="{Binding HotkeyDescription, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource PrimaryLightBrush}" />
                            <Run Text=" to record" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox x:Name="NavList" Margin="8,10"
                         Background="Transparent" BorderThickness="0"
                         SelectedIndex="0" SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,10" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="{StaticResource MediumRadius}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource SurfaceHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource SurfaceBrush}" />
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource TextPrimaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="Home" />
                    <ListBoxItem Content="History" />
                    <ListBoxItem Content="Stats" />
                    <ListBoxItem Content="Dictionary" />
                    <ListBoxItem Content="Style" />
                    <ListBoxItem Content="Settings" />
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
