{
  "name": "verbalize-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute verbalize-db --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute verbalize-db --remote --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute verbalize-db --local --file=migrations/latest.sql",
    "db:migrate:remote": "wrangler d1 execute verbalize-db --remote --file=migrations/latest.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
